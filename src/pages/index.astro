---
import Layout from '../layouts/Layout.astro';

const fuelPrice = 1.59;
const tankSize = 55;
const currentFuelPercent = 70;
const currentFuelLitres = (tankSize * currentFuelPercent) / 100;
const costToFill = ((tankSize - currentFuelLitres) * fuelPrice).toFixed(2);
const mileage = 98123;
---

<Layout title="My Garage">
  <main class="mx-auto flex max-w-6xl flex-col gap-4 p-4 sm:p-6 lg:p-8">
    <section class="overflow-hidden rounded-[2rem] border border-white/10 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-700 p-6 shadow-2xl shadow-black/30 sm:p-8">
      <div class="grid gap-4 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="rounded-[1.5rem] border border-white/10 bg-white/10 p-6 backdrop-blur">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Garage</p>
              <h1 class="mt-2 text-4xl font-semibold text-white sm:text-5xl">My Garage</h1>
            </div>
            <div class="rounded-full bg-emerald-400/20 px-3 py-1 text-sm font-medium text-emerald-300">
              Running
            </div>
          </div>

          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="rounded-2xl bg-slate-950/50 p-4">
              <p class="text-sm text-slate-400">Model</p>
              <p class="mt-1 text-xl font-semibold text-white">BMW M140i</p>
            </div>
            <div class="rounded-2xl bg-slate-950/50 p-4">
              <p class="text-sm text-slate-400">Mileage</p>
              <p class="mt-1 text-xl font-semibold text-white">{mileage} mi</p>
            </div>
          </div>
        </div>

        <div class="space-y-4">
          <div class="rounded-[1.5rem] bg-amber-400 p-6 text-slate-900 shadow-lg shadow-amber-400/20">
            <p class="text-sm uppercase tracking-[0.3em] text-slate-700">Fuel</p>
            <p class="mt-2 text-4xl font-semibold">{currentFuelPercent}%</p>
            <p class="mt-1 text-sm text-slate-700">{fuelPrice.toFixed(2)}£ / litre</p>
          </div>

          <div class="rounded-[1.5rem] bg-emerald-400 p-6 text-slate-900 shadow-lg shadow-emerald-400/20">
            <p class="text-sm uppercase tracking-[0.3em] text-slate-700">Weather</p>
            <p class="mt-2 text-4xl font-semibold">22°C</p>
            <p class="mt-1 text-sm text-slate-700">Sunny • clear roads</p>
          </div>
        </div>
      </div>
    </section>

    <section class="grid gap-4 md:grid-cols-3">
      <article class="rounded-[1.5rem] border border-amber-400/30 bg-amber-500/10 p-6 shadow-sm">
        <p class="text-sm font-medium text-amber-300">Tank</p>
        <p class="mt-2 text-3xl font-semibold text-white">{tankSize}L</p>
        <p class="mt-3 text-sm text-slate-300">To fill up: £{costToFill}</p>
      </article>

      <article class="rounded-[1.5rem] border border-sky-400/30 bg-sky-500/10 p-6 shadow-sm">
        <p class="text-sm font-medium text-sky-300">Mods</p>
        <p class="mt-2 text-xl font-semibold text-white">19" alloys</p>
        <p class="mt-1 text-sm text-slate-300">LED lights • Stage 1</p>
      </article>

      <article class="rounded-[1.5rem] border border-fuchsia-400/30 bg-fuchsia-500/10 p-6 shadow-sm">
        <p class="text-sm font-medium text-fuchsia-300">Status</p>
        <p class="mt-2 text-3xl font-semibold text-white">Ready</p>
        <p class="mt-3 text-sm text-slate-300">Smooth and reliable</p>
      </article>
    </section>
  </main>
</Layout>